# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Option A: Your own Anthropic key (direct API access)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option B: Replit AI Integration (auto-provisioned, no key needed)
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=<set automatically by Replit>
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=<set automatically by Replit>
